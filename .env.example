# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=vaultfinance

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis

# Backend API
API_PORT=3000
API_PREFIX=/api
NODE_ENV=development

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-jwt-secret-key-change-in-production

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Blockchain RPC (Bitcoin/OP_CAT Layer)
BLOCKCHAIN_RPC_URL=http://localhost:38443
BLOCKCHAIN_RPC_USER=user
BLOCKCHAIN_RPC_PASSWORD=password
BLOCKCHAIN_NETWORK=regtest

# Vault Contract Configuration
VAULT_GENESIS_OUTPOINT=
VAULT_SCRIPT_HASH=

# Oracle Configuration
ORACLE_PUBKEY_N=
ORACLE_API_URL=

# Fee Configuration
FLASH_LOAN_FEE_RATE=9  # 0.09% = 9 bps

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty
